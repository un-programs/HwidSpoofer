<Window x:Class="HwidSpoofer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HwidSpoofer.ViewModels"
        xmlns:conv="clr-namespace:HwidSpoofer.Converters"
        Title="HWID Spoofer"
        Width="650" Height="440"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToYesNoConverter x:Key="BoolToYesNo"/>
        <conv:BoolToOnOffConverter x:Key="BoolToOnOff"/>
        <conv:BoolToStatusColorConverter x:Key="BoolToStatusColor"/>

        <SolidColorBrush x:Key="WindowBg" Color="#FF161728"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#FF4A6CF7"/>
        <SolidColorBrush x:Key="AccentHover" Color="#FF5E7EFF"/>
        <SolidColorBrush x:Key="SidebarBg" Color="#FF1A1C30"/>
        <SolidColorBrush x:Key="CardBg" Color="#FF1E2038"/>
        <SolidColorBrush x:Key="ContentBorder" Color="#FF2A2D48"/>
        <SolidColorBrush x:Key="TextWhite" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextDimmed" Color="#FF7880A0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#FF4A4E68"/>

        <!-- Scrollbar thumb -->
        <Style x:Key="SlimThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="bd" Background="#44FFFFFF" CornerRadius="3" Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#66FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical scrollbar -->
        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="Transparent" CornerRadius="3"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark-themed ScrollViewer -->
        <Style x:Key="DarkScrollViewer" TargetType="ScrollViewer">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Margin="0,0,4,0"/>
                            <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource SlimScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab button style -->
        <Style x:Key="TabBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimmed}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Setter Property="Padding" Value="0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="txt"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="txt" Property="Foreground" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txt" Property="Foreground" Value="{StaticResource TextWhite}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar icon button -->
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimmed}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="8"
                                Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Blue card button -->
        <Style x:Key="BlueCard" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="16,12">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Spoof main button -->
        <Style x:Key="SpoofBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="20,14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window control button -->
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimmed}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer border with rounded corners and shadow -->
    <Border CornerRadius="14"
            Background="{StaticResource WindowBg}"
            BorderBrush="{StaticResource ContentBorder}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.5" Color="#000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="28"/>   <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ═══════ TITLE BAR ═══════ -->
            <Grid Grid.Row="0" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>  <!-- Logo space -->
                    <ColumnDefinition Width="*"/>   <!-- Tabs -->
                    <ColumnDefinition Width="Auto"/><!-- Window buttons -->
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Border Grid.Column="0" Margin="14,10,0,0">
                    <Viewbox Width="30" Height="30">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12 2L2 7v10l10 5 10-5V7L12 2zm0 2.2L19.8 8 12 11.8 4.2 8 12 4.2z"
                                  Fill="{StaticResource AccentBlue}"/>
                            <Path Data="M12 13v8.5l8-4V9.5L12 13z" Fill="#FF3A58CC" Opacity="0.8"/>
                            <Path Data="M12 13v8.5l-8-4V9.5L12 13z" Fill="#FF5570E8" Opacity="0.6"/>
                        </Canvas>
                    </Viewbox>
                </Border>

                <!-- Tab navigation -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="10,2,0,0">
                    <RadioButton Content="Spoofer" Style="{StaticResource TabBtn}"
                                 IsChecked="{Binding IsTabSpoofer}" GroupName="tabs"/>
                    <RadioButton Content="Serials" Style="{StaticResource TabBtn}"
                                 IsChecked="{Binding IsTabSerials}" GroupName="tabs"/>
                    <RadioButton Content="Instructions" Style="{StaticResource TabBtn}"
                                 IsChecked="{Binding IsTabInstructions}" GroupName="tabs"/>
                    <RadioButton Content="Driver" Style="{StaticResource TabBtn}"
                                 IsChecked="{Binding IsTabDriver}" GroupName="tabs"/>
                </StackPanel>

                <!-- Window controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Top" Margin="0,8,12,0">
                    <Button Style="{StaticResource WinBtn}" Content="—" Click="Minimize_Click"/>
                    <Button Style="{StaticResource WinBtn}" Content="✕" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- ═══════ MAIN CONTENT ═══════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>  <!-- Sidebar -->
                    <ColumnDefinition Width="*"/>   <!-- Content -->
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Top" Style="{StaticResource SidebarBtn}" Margin="5,10,5,0"
                                ToolTip="Home">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"
                                          Fill="{StaticResource AccentBlue}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <Button DockPanel.Dock="Bottom" Style="{StaticResource SidebarBtn}" Margin="5,0,5,10"
                                ToolTip="Discord">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"
                                          Fill="{StaticResource TextDimmed}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- Content area -->
                <Grid Grid.Column="1" Margin="16,6,16,10">

                    <!-- ══ TAB: Spoofer ══ -->
                    <Grid Visibility="{Binding IsTabSpoofer, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Log output area -->
                        <Border Grid.Row="0"
                                Background="{StaticResource CardBg}"
                                BorderBrush="{StaticResource ContentBorder}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Output"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11" FontWeight="SemiBold" Margin="4,0,0,4"/>
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding LogEntries}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource TextDimmed}"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,1"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Grid.Row="1"
                                           Text="Waiting for spoof..."
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsLogEmpty, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Border>

                        <!-- Spoof button -->
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Button Style="{StaticResource SpoofBtn}"
                                    Command="{Binding SpoofCommand}"
                                    IsEnabled="{Binding IsNotSpoofing}"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Spoof" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DebugTag}" Foreground="#AAFFFFFF"
                                               FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <ProgressBar IsIndeterminate="True" Height="3"
                                         VerticalAlignment="Bottom"
                                         Visibility="{Binding IsSpoofing, Converter={StaticResource BoolToVis}}"
                                         Foreground="{StaticResource AccentBlue}"
                                         Background="Transparent" BorderThickness="0"
                                         Margin="0,0,0,-1"/>
                        </Grid>
                    </Grid>

                    <!-- ══ TAB: Serials ══ -->
                    <Grid Visibility="{Binding IsTabSerials, Converter={StaticResource BoolToVis}}">
                        <Border Background="{StaticResource CardBg}"
                                BorderBrush="{StaticResource ContentBorder}"
                                BorderThickness="1" CornerRadius="10" Padding="20,16">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource DarkScrollViewer}">
                                <StackPanel>
                                    <TextBlock Text="SYSTEM SERIALS"
                                               Foreground="{StaticResource AccentBlue}"
                                               FontSize="13" FontWeight="Bold" Margin="0,0,0,16"/>

                                    <TextBlock Text="MAC Address" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    <TextBlock Text="{Binding MacAddress}" Foreground="{StaticResource TextWhite}"
                                               FontFamily="Consolas" FontSize="13" Margin="0,2,0,12"/>

                                    <TextBlock Text="Volume Serial" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    <TextBlock Text="{Binding VolumeSerial}" Foreground="{StaticResource TextWhite}"
                                               FontFamily="Consolas" FontSize="13" Margin="0,2,0,12"/>

                                    <TextBlock Text="Processor ID" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    <TextBlock Text="{Binding ProcessorId}" Foreground="{StaticResource TextWhite}"
                                               FontFamily="Consolas" FontSize="13" Margin="0,2,0,12"/>

                                    <TextBlock Text="Baseboard Serial" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    <TextBlock Text="{Binding BaseboardSerial}" Foreground="{StaticResource TextWhite}"
                                               FontFamily="Consolas" FontSize="13" Margin="0,2,0,12"/>

                                    <TextBlock Text="Product ID" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    <TextBlock Text="{Binding ProductId}" Foreground="{StaticResource TextWhite}"
                                               FontFamily="Consolas" FontSize="13" Margin="0,2,0,12"/>

                                    <TextBlock Text="Machine GUID" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    <TextBlock Text="{Binding MachineGuid}" Foreground="{StaticResource TextWhite}"
                                               FontFamily="Consolas" FontSize="13" Margin="0,2,0,12"/>

                                    <TextBlock Text="Computer Name" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    <TextBlock Text="{Binding ComputerName}" Foreground="{StaticResource TextWhite}"
                                               FontFamily="Consolas" FontSize="13" Margin="0,2,0,12"/>

                                    <Button Content="Refresh" Command="{Binding RefreshCommand}"
                                            Style="{StaticResource BlueCard}"
                                            HorizontalAlignment="Left" Margin="0,4,0,0"
                                            Padding="24,8" Height="Auto"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- ══ TAB: Instructions ══ -->
                    <Grid Visibility="{Binding IsTabInstructions, Converter={StaticResource BoolToVis}}">
                        <Border Background="{StaticResource CardBg}"
                                BorderBrush="{StaticResource ContentBorder}"
                                BorderThickness="1" CornerRadius="10" Padding="20,16">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource DarkScrollViewer}">
                                <StackPanel>
                                    <TextBlock Text="HOW TO USE"
                                               Foreground="{StaticResource AccentBlue}"
                                               FontSize="13" FontWeight="Bold" Margin="0,0,0,16"/>

                                    <TextBlock Foreground="{StaticResource TextWhite}" FontSize="13"
                                               TextWrapping="Wrap" LineHeight="22">
                                        <Run FontWeight="Bold" Text="1."/><Run Text=" Run the application as Administrator."/>
                                        <LineBreak/><LineBreak/>
                                        <Run FontWeight="Bold" Text="2."/><Run Text=" Go to the Serials tab to view your current hardware identifiers."/>
                                        <LineBreak/><LineBreak/>
                                        <Run FontWeight="Bold" Text="3."/><Run Text=" Close all game launchers (Steam, Epic, Riot, etc)."/>
                                        <LineBreak/><LineBreak/>
                                        <Run FontWeight="Bold" Text="4."/><Run Text=" Go to the Spoofer tab and click the Spoof button."/>
                                        <LineBreak/><LineBreak/>
                                        <Run FontWeight="Bold" Text="5."/><Run Text=" Wait for the process to complete. Watch the output log."/>
                                        <LineBreak/><LineBreak/>
                                        <Run FontWeight="Bold" Text="6."/><Run Text=" Restart your computer for all changes to take effect."/>
                                        <LineBreak/><LineBreak/>
                                        <Run FontWeight="Bold" Foreground="#FF4A6CF7" Text="Note: "/><Run Text="Some changes (like volume serial) only apply after a reboot."/>
                                    </TextBlock>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- ══ TAB: Driver ══ -->
                    <Grid Visibility="{Binding IsTabDriver, Converter={StaticResource BoolToVis}}">
                        <Border Background="{StaticResource CardBg}"
                                BorderBrush="{StaticResource ContentBorder}"
                                BorderThickness="1" CornerRadius="10" Padding="20,14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource DarkScrollViewer}">
                                <StackPanel>
                                    <!-- Header -->
                                    <TextBlock Text="SYSTEM STATUS"
                                               Foreground="{StaticResource AccentBlue}"
                                               FontSize="13" FontWeight="Bold" Margin="0,0,0,14"/>

                                    <!-- System checks grid -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Administrator" Foreground="{StaticResource TextWhite}" FontSize="12"/>
                                        <TextBlock Grid.Column="1" FontSize="12" FontFamily="Consolas"
                                                   Foreground="{Binding IsAdmin, Converter={StaticResource BoolToStatusColor}}"
                                                   Text="{Binding IsAdmin, Converter={StaticResource BoolToYesNo}}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Test Signing" Foreground="{StaticResource TextWhite}" FontSize="12"/>
                                        <TextBlock Grid.Column="1" FontSize="12" FontFamily="Consolas"
                                                   Foreground="{StaticResource TextDimmed}"
                                                   Text="{Binding IsTestSigning, Converter={StaticResource BoolToOnOff}}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Secure Boot" Foreground="{StaticResource TextWhite}" FontSize="12"/>
                                        <TextBlock Grid.Column="1" FontSize="12" FontFamily="Consolas"
                                                   Foreground="{StaticResource TextDimmed}"
                                                   Text="{Binding IsSecureBoot, Converter={StaticResource BoolToOnOff}}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Windows Defender" Foreground="{StaticResource TextWhite}" FontSize="12"/>
                                        <TextBlock Grid.Column="1" FontSize="12" FontFamily="Consolas"
                                                   Foreground="{StaticResource TextDimmed}"
                                                   Text="{Binding DefenderStatus}"/>
                                    </Grid>

                                    <!-- Separator -->
                                    <Border Height="1" Background="{StaticResource ContentBorder}" Margin="0,8,0,12"/>

                                    <!-- Anti-cheat section -->
                                    <TextBlock Text="ANTI-CHEAT SERVICES"
                                               Foreground="{StaticResource AccentBlue}"
                                               FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                                    <ItemsControl ItemsSource="{Binding AntiCheatEntries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                               Foreground="{StaticResource TextWhite}" FontSize="11.5"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Detail}"
                                                               FontSize="11.5" FontFamily="Consolas"
                                                               Foreground="{StaticResource TextDimmed}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Separator -->
                                    <Border Height="1" Background="{StaticResource ContentBorder}" Margin="0,10,0,12"/>

                                    <!-- Readiness -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Spoof Readiness"
                                                   Foreground="{StaticResource TextWhite}" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SpoofReadiness}"
                                                   FontSize="12" FontFamily="Consolas"
                                                   Foreground="{StaticResource AccentBlue}"/>
                                    </Grid>

                                    <!-- Refresh button -->
                                    <Button Content="Refresh" Command="{Binding RefreshDriverCommand}"
                                            Style="{StaticResource BlueCard}"
                                            HorizontalAlignment="Left" Margin="0,0,0,0"
                                            Padding="24,8" Height="Auto"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ═══════ FOOTER ═══════ -->
            <Border Grid.Row="2">
                <TextBlock Text="{Binding FooterText}"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
